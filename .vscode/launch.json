{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "citus_test",
      "type": "debugpy",
      "request": "launch",
      "cwd": "${workspaceFolder}/main/citus",
      "program": "citus_test.py",
      "console": "integratedTerminal"
    },
    {
      "name": "Debug distranger-citus",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/distranger",
      "args": [
        "main/citus/citus_ddc_config.txt"
      ],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    },
